{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["pod", "runId", "snapshotDate", "recommendations"],
  "properties": {
    "pod": { "const": "STRATEGIST" },
    "runId": { "type": "string", "minLength": 1 },
    "snapshotDate": { "type": "string", "minLength": 1 },
    "recommendations": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/remediation" }
    }
  },
  "additionalProperties": true
}
