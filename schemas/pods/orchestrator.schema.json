{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["runId", "snapshotDate", "releaseReady", "buildStatus", "criticalAlerts", "warningAlerts", "podResults"],
  "properties": {
    "runId": { "type": "string", "minLength": 1 },
    "snapshotDate": { "type": "string", "minLength": 1 },
    "releaseReady": { "type": "boolean" },
    "buildStatus": { "type": "string" },
    "criticalAlerts": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/remediation" }
    },
    "warningAlerts": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/remediation" }
    },
    "podResults": { "type": "object" },
    "dashboardSyncStatus": { "type": "string" }
  },
  "additionalProperties": true
}
