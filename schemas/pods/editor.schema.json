  "type": "object",
  "required": ["pod", "runId", "snapshotDate", "violations", "readability"],
  "properties": {
    "pod": { "const": "EDITOR" },
    "runId": { "type": "string", "minLength": 1 },
    "snapshotDate": { "type": "string", "minLength": 1 },
    "violations": { "type": "object" },
    "readability": { "type": "object" }
  },
  "additionalProperties": true
}
